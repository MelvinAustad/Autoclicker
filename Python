def hotkey_display(key: Key | KeyCode) -> str:
    """
    Convert a keyboard key to a human-readable display string.

    Args:
        key: A pynput Key or KeyCode object

    Returns:
        A formatted string representation of the key
    """
    if isinstance(key, KeyCode):
        if key.char is not None:
            return key.char.upper()
        return f"VK:{key.vk}"
    if isinstance(key, Key):
        name = key.name
        return name.upper() if (name.startswith("f") and name[1:].isdigit()) else name.capitalize()
    return str(key)


def hotkey_serialize(key: Key | KeyCode) -> str:
    """
    Serialize a keyboard key for JSON storage.

    Args:
        key: A pynput Key or KeyCode object

    Returns:
        A serializable string representation
    """
    if isinstance(key, KeyCode) and key.char is not None:
        return f"char:{key.char}"
    if isinstance(key, KeyCode):
        return f"vk:{key.vk}"
    if isinstance(key, Key):
        return f"key:{key.name}"
    return "key:f6"


def hotkey_deserialize(serialized: str) -> Key | KeyCode:
    """
    Deserialize a keyboard key from JSON storage.

    Args:
        serialized: A serialized key string

    Returns:
        A pynput Key or KeyCode object, defaults to F6 on error
    """
    try:
        parts = serialized.split(":", 1)
        kind, val = parts[0], parts[1] if len(parts) > 1 else ""

        if kind == "char":
            return KeyCode.from_char(val)
        if kind == "vk":
            return KeyCode.from_vk(int(val))
        if kind == "key":
            return Key[val]
    except (KeyError, ValueError, AttributeError) as e:
        logger.warning(f"Failed to deserialize hotkey '{serialized}': {e}")
    return Key.f6


class ClickerEngine:
    """Background thread that performs mouse clicks at configurable intervals."""

    def __init__(self):
        """Initialize the clicker engine."""
        self.active = False
        self.running = True
        self.interval = 0.1  # seconds between clicks
        self.button = Button.left
        self.clicks = 1  # single, double, or triple click
        self.mouse = MouseController()
        self.fixed_pos = None
        self.use_fixed_pos = False
        self.auto_stop_duration = 0  # seconds, 0 = disabled
        self.auto_stop_start = 0.0
        self._thread = None
        self._lock = threading.Lock()

    def start(self) -> None:
        """Start the clicking engine."""
        with self._lock:
            if not self.active:
                self.active = True
                self.auto_stop_start = time.time()
                if self._thread is None or not self._thread.is_alive():
                    self._thread = threading.Thread(target=self._loop, daemon=True)
                    self._thread.start()
                logger.info("Clicker engine started")

    def stop(self) -> None:
        """Stop the clicking engine."""
        with self._lock:
            if self.active:
                self.active = False
                logger.info("Clicker engine stopped")

    def toggle(self) -> None:
        """Toggle the clicking engine on/off."""
        self.stop() if self.active else self.start()

    def shutdown(self) -> None:
        """Shutdown the clicking engine gracefully."""
        with self._lock:
            self.running = False
            self.active = False
        logger.info("Clicker engine shutdown")

    def _loop(self) -> None:
        """Main loop for the clicking engine."""
        while self.running:
            if self.active:
                # Check if auto-stop duration has been reached
                if self.auto_stop_duration > 0:
                    elapsed = time.time() - self.auto_stop_start
                    if elapsed >= self.auto_stop_duration:
                        self.active = False
                        continue

                # Move mouse to fixed position if enabled
                if self.use_fixed_pos and self.fixed_pos:
                    try:
                        self.mouse.position = self.fixed_pos
                    except Exception as e:
                        logger.error(f"Failed to set mouse position: {e}")

                # Perform click
                try:
                    self.mouse.click(self.button, self.clicks)
                except Exception as e:
                    logger.error(f"Failed to perform click: {e}")

                # Sleep with responsive shutdown
                remaining = self.interval
                while remaining > 0 and self.running and self.active:
                    chunk = min(0.05, remaining)
                    time.sleep(chunk)
                    remaining -= chunk
            else:
                time.sleep(0.05)


