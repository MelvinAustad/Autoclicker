    def _on_interval_change(self, value: float) -> None:
        """Handle interval slider changes."""
        self.interval_label.configure(text=f"{value:.2f}s")
        self.engine.interval = value
        cps = 1.0 / value if value > 0 else 0
        self.cps_entry.delete(0, "end")
        self.cps_entry.insert(0, f"{cps:.1f}")

    def _on_cps_change(self, event=None) -> None:
        """Handle CPS input changes."""
        try:
            cps = float(self.cps_entry.get())
            if cps > 0:
                interval = max(0.01, min(5.0, 1.0 / cps))
                self.interval_var.set(interval)
                self.interval_slider.set(interval)
                self.engine.interval = interval
                self.interval_label.configure(text=f"{interval:.2f}s")
                actual_cps = 1.0 / interval
                self.cps_entry.delete(0, "end")
                self.cps_entry.insert(0, f"{actual_cps:.1f}")
        except ValueError:
            logger.debug("Invalid CPS value entered")

    def _on_click_type_change(self, choice: str) -> None:
        """Handle click type selection changes."""
        mapping = {"Single": 1, "Double": 2, "Triple": 3}
        self.engine.clicks = mapping.get(choice, 1)

    def _on_button_change(self, choice: str) -> None:
        """Handle mouse button selection changes."""
        mapping = {
            "Left": Button.left,
            "Right": Button.right,
            "Middle": Button.middle
        }
        self.engine.button = mapping.get(choice, Button.left)

    def _on_location_change(self) -> None:
        """Handle click location selection changes."""
        fixed = self.location_var.get() == "fixed"
        self.engine.use_fixed_pos = fixed
        if fixed:
            self.set_pos_btn.pack(side="left", padx=(0, 8))
            self.pos_label.pack(side="left")
        else:
            self.set_pos_btn.pack_forget()
            self.pos_label.pack_forget()

    def _on_set_position(self) -> None:
        """Initiate position capture countdown."""
        self.set_pos_btn.configure(text="3", state="disabled")
        self.after(1000, self._countdown_2)

    def _countdown_2(self) -> None:
        """Second countdown step."""
        self.set_pos_btn.configure(text="2")
        self.after(1000, self._countdown_1)

    def _countdown_1(self) -> None:
        """Final countdown step."""
        self.set_pos_btn.configure(text="1")
        self.after(1000, self._capture_position)

    def _capture_position(self) -> None:
        """Capture current mouse position."""
        pos = self.engine.mouse.position
        self.engine.fixed_pos = pos
        self.pos_label.configure(text=f"({int(pos[0])}, {int(pos[1])})")
        self.set_pos_btn.configure(text="\U0001f4cd Set", state="normal")
        logger.info(f"Position captured: {pos}")

    def _on_record(self) -> None:
        """Start hotkey recording mode."""
        self.recording = True
        self.record_btn.configure(text="Press a key\u2026", fg_color=RED)
        self.after(5000, self._cancel_record)
        logger.info("Hotkey recording started")

    def _cancel_record(self) -> None:
        """Cancel hotkey recording mode."""
        if self.recording:
            self.recording = False
            self.record_btn.configure(text="\u2328 Record", fg_color=OVERLAY)
            logger.info("Hotkey recording cancelled (timeout)")

    def _on_auto_stop_change(self) -> None:
        """Handle auto-stop checkbox changes."""
        if not self.auto_stop_var.get():
            self.engine.auto_stop_duration = 0

    def _update_auto_stop(self) -> None:
        """Update auto-stop duration from UI inputs."""
        if not self.auto_stop_var.get():
            self.engine.auto_stop_duration = 0
            return
        try:
            hours = int(self.auto_stop_hours.get() or "0")
            minutes = int(self.auto_stop_mins.get() or "0")
            seconds = int(self.auto_stop_secs.get() or "0")
            self.engine.auto_stop_duration = hours * 3600 + minutes * 60 + seconds
        except ValueError:
            logger.warning("Invalid auto-stop duration values")
            self.engine.auto_stop_duration = 0

    def _on_toggle(self) -> None:
        """Handle start/stop button click."""
        self._update_auto_stop()
        self.engine.toggle()
        if self.engine.active:
            self.engine.auto_stop_start = time.time()
            self.toggle_btn.configure(
                text="\u25a0  Stop", fg_color=RED,
                hover_color="#e64553"
            )
            logger.info("Clicking started")
        else:
            self.toggle_btn.configure(
                text="\u25b6  Start Clicking", fg_color=BLUE,
                hover_color=MAUVE
            )
            logger.info("Clicking stopped")

    def _tick_status(self) -> None:
        """Update status display."""
        if self.engine.active:
            self.status_dot.configure(text_color=GREEN)
            self.status_label.configure(text="Running")

            parts = [
                f"{1.0 / self.engine.interval:.1f} CPS",
                ["", "Single", "Double", "Triple"][self.engine.clicks],
                ["Left", "Right", "Middle"][
                    [Button.left, Button.right, Button.middle]
                    .index(self.engine.button)
                ],
            ]

            if self.engine.auto_stop_duration > 0:
                elapsed = time.time() - self.engine.auto_stop_start
                remaining = max(0, self.engine.auto_stop_duration - elapsed)
                parts.append(
                    f"{'-' if remaining <= 0 else ''}"
                    f"{int(remaining // 3600):02d}:"
                    f"{int((remaining % 3600) // 60):02d}:"
                    f"{int(remaining % 60):02d}"
                )

            self.status_info.configure(text="  \u2022  ".join(parts))
        else:
            self.status_dot.configure(text_color=SUBTEXT)
            self.status_label.configure(text="Ready")
            self.status_info.configure(text="")

        self.footer_hotkey.configure(
            text=f"Press  {hotkey_display(self.hotkey)}  to toggle"
        )
        self.after(500, self._tick_status)

    def _start_listener(self) -> None:
        """Start global keyboard listener."""
        def on_press(key):
            try:
                if self.recording:
                    self.recording = False
                    self.after(0, lambda: self._set_hotkey(key))
                    return
                if key == self.hotkey:
                    self.after(0, self._on_toggle)
            except Exception as e:
                logger.error(f"Keyboard listener error: {e}")

        try:
            self._listener = KeyboardListener(on_press=on_press)
            self._listener.start()
            logger.info("Keyboard listener started")
        except Exception as e:
            logger.error(f"Failed to start keyboard listener: {e}")

    def _set_hotkey(self, key: Key | KeyCode) -> None:
        """Set a new hotkey."""
        self.hotkey = key
        self.hotkey_entry.configure(state="normal")
        self.hotkey_entry.delete(0, "end")
        self.hotkey_entry.insert(0, hotkey_display(key))
        self.hotkey_entry.configure(state="readonly")
        self.record_btn.configure(text="\u2328 Record", fg_color=OVERLAY)
        logger.info(f"Hotkey set to {hotkey_display(key)}")

    def _on_close(self) -> None:
        """Handle application close."""
        logger.info("Closing application")
        self.engine.shutdown()
        if self._listener:
            self._listener.stop()
        self._save_config()
        self.destroy()

    def _load_config(self) -> None:
        """Load configuration from file."""
        try:
            if not CONFIG_FILE.exists():
                logger.info("No config file found, using defaults")
                return

            with open(CONFIG_FILE) as f:
                cfg = json.load(f)
            logger.info("Configuration loaded successfully")

            # Interval
            self.engine.interval = cfg.get("interval", 0.1)
            self.interval_var.set(self.engine.interval)
            self.interval_slider.set(self.engine.interval)
            self.interval_label.configure(text=f"{self.engine.interval:.2f}s")
            cps = 1.0 / self.engine.interval
            self.cps_entry.delete(0, "end")
            self.cps_entry.insert(0, f"{cps:.1f}")

            # Click type and button
            self.click_type_var.set(cfg.get("click_type", "Single"))
            self.mouse_btn_var.set(cfg.get("mouse_button", "Left"))

            # Location
            location = cfg.get("location", "cursor")
            self.location_var.set(location)
            if location == "fixed":
                self.engine.use_fixed_pos = True
                fixed_x = cfg.get("fixed_x", 0)
                fixed_y = cfg.get("fixed_y", 0)
                self.engine.fixed_pos = (fixed_x, fixed_y)
                self.pos_label.configure(text=f"({fixed_x}, {fixed_y})")
                self.set_pos_btn.pack(side="left", padx=(0, 8))
                self.pos_label.pack(side="left")

            # Hotkey
            hotkey_str = cfg.get("hotkey", "")
            if hotkey_str:
                key = hotkey_deserialize(hotkey_str)
                if key:
                    self.hotkey = key
                    self.hotkey_entry.configure(state="normal")
                    self.hotkey_entry.delete(0, "end")
                    self.hotkey_entry.insert(0, hotkey_display(key))
                    self.hotkey_entry.configure(state="readonly")

            # Auto-stop
            if cfg.get("auto_stop_enabled", False):
                self.auto_stop_var.set(True)
                hours = cfg.get("auto_stop_hours", 0)
                minutes = cfg.get("auto_stop_mins", 0)
                seconds = cfg.get("auto_stop_secs", 0)
                self.auto_stop_hours.delete(0, "end")
                self.auto_stop_hours.insert(0, str(hours))
                self.auto_stop_mins.delete(0, "end")
                self.auto_stop_mins.insert(0, str(minutes))
                self.auto_stop_secs.delete(0, "end")
                self.auto_stop_secs.insert(0, str(seconds))
                self.engine.auto_stop_duration = hours * 3600 + minutes * 60 + seconds

        except Exception as e:
            logger.error(f"Failed to load configuration: {e}")

    def _save_config(self) -> None:
        """Save configuration to file."""
        try:
            CONFIG_DIR.mkdir(parents=True, exist_ok=True)

            cfg = {
                "hotkey": hotkey_serialize(self.hotkey),
                "interval": self.engine.interval,
                "click_type": self.click_type_var.get(),
                "mouse_button": self.mouse_btn_var.get(),
                "location": self.location_var.get(),
                "auto_stop_enabled": self.auto_stop_var.get(),
            }

            if self.engine.fixed_pos:
                cfg["fixed_x"] = int(self.engine.fixed_pos[0])
                cfg["fixed_y"] = int(self.engine.fixed_pos[1])

            if self.auto_stop_var.get():
                try:
                    cfg["auto_stop_hours"] = int(self.auto_stop_hours.get() or "0")
                    cfg["auto_stop_mins"] = int(self.auto_stop_mins.get() or "0")
                    cfg["auto_stop_secs"] = int(self.auto_stop_secs.get() or "0")
                except ValueError:
                    pass

            with open(CONFIG_FILE, "w") as f:
                json.dump(cfg, f, indent=2)
            logger.info("Configuration saved successfully")

        except Exception as e:
            logger.error(f"Failed to save configuration: {e}")


def main() -> None:
    """Main entry point."""
    ctk.set_appearance_mode("dark")
    ctk.set_default_color_theme("blue")
    app = App()
    try:
        app.mainloop()
    except KeyboardInterrupt:
        logger.info("Received keyboard interrupt")
        app._on_close()


if __name__ == "__main__":
    main()
